set -e

basedir=$( cd -- "$(dirname -- "$0")" && pwd )
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$basedir}"

MVN_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

JAVA_EXE="java"
if [ -n "$JAVA_HOME" ]; then
  JAVA_EXE="$JAVA_HOME/bin/java"
fi

if [ -r "$MVN_JAR" ]; then
  CLASSPATH="$MVN_JAR"
  WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"
  exec "$JAVA_EXE" "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" -cp "$CLASSPATH" "$WRAPPER_LAUNCHER" "$@"
else
  echo "Downloading maven-wrapper..."

  WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
  WRAPPER_URL=$(grep -F "wrapperUrl" "$WRAPPER_PROPERTIES" | cut -d= -f2)

  mkdir -p "$MAVEN_PROJECTBASEDIR/.mvn/wrapper"

  curl -sL "$WRAPPER_URL" -o "$MVN_JAR" || (echo "Failed to download maven-wrapper.jar" && exit 1)

  exec "$JAVA_EXE" "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" -cp "$MVN_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
fi
